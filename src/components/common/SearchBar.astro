---
export interface Props {
  placeholder?: string;
  className?: string;
}

const { placeholder = "搜尋文章...", className = "" } = Astro.props;
---

<div class={`relative ${className}`}>
  <div class="relative">
    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-ink-soft">
      <svg
        class="w-5 h-5"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"
        />
      </svg>
    </div>
    <label for="blog-search"></label><input
      type="search"
      id="blog-search"
      class="hd-input !pl-11"
      placeholder={placeholder}
      autocomplete="on"
    />
  </div>
</div>
