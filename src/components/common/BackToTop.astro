<div class="back-to-top fixed bottom-8 right-8 opacity-0 invisible transition-all z-30">
    <button
        id="back-to-top-button"
        class="hd-icon-circle !w-12 !h-12 !bg-surface"
        aria-label="回到頂部"
    >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12l5-5 5 5M10 7v9" />
        </svg>
    </button>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const backToTopButton = document.getElementById('back-to-top-button');
        const backToTopContainer = document.querySelector('.back-to-top');

        if (backToTopButton && backToTopContainer) {
            const toggleBackToTopButton = () => {
                if (window.scrollY > 300) {
                    backToTopContainer.classList.add('visible');
                } else {
                    backToTopContainer.classList.remove('visible');
                }
            };

            toggleBackToTopButton();
            window.addEventListener('scroll', toggleBackToTopButton);
            backToTopButton.addEventListener('click', () => {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }
    });
</script>
