---
import CVSection from './CVSection.astro';
import type { ProjectItem } from '../../types/cv';

interface Props {
  items: ProjectItem[];
}
const { items } = Astro.props;

const visibleItems = items.filter(p => p.title.en);

const typeColor: Record<string, string> = {
  'Blog':                 'bg-sky-50 text-sky-700 ring-sky-200',
  'Blog Series':          'bg-indigo-50 text-indigo-700 ring-indigo-200',
  'SDK':                  'bg-emerald-50 text-emerald-700 ring-emerald-200',
  'Certification':        'bg-amber-50 text-amber-700 ring-amber-200',
  'GDG Kaohsiung Speaker':'bg-rose-50 text-rose-700 ring-rose-200',
};
const defaultBadge = 'bg-gray-50 text-gray-600 ring-gray-200';
---

<CVSection title="Projects &amp; Highlights">
  <div class="pl-5 grid gap-2">
    {visibleItems.map((item) => (
      <div class="flex items-start justify-between gap-4 py-1.5 border-b border-gray-50 last:border-0">
        <div class="flex items-start gap-2 min-w-0">
          <span class="mt-[5px] shrink-0 w-1.5 h-1.5 rounded-full bg-blue-400"></span>
          {item.link ? (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[13px] text-gray-800 hover:text-blue-600 transition-colors truncate"
            >
              {item.title.en}
            </a>
          ) : (
            <span class="text-[13px] text-gray-800 truncate">{item.title.en}</span>
          )}
        </div>
        <span class={`shrink-0 text-[11px] font-medium px-2 py-0.5 rounded-full ring-1 whitespace-nowrap ${typeColor[item.type.en] ?? defaultBadge}`}>
          {item.type.en}
        </span>
      </div>
    ))}
  </div>
</CVSection>
