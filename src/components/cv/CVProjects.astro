---
import CVSection from './CVSection.astro';
import { getLocalizedText } from '../../utils/i18n';
import type { ProjectItem, Language } from '../../types/cv';

interface Props {
  items: ProjectItem[];
  lang?: Language;
}
const { items, lang = 'en' } = Astro.props;

const visibleItems = items.filter(p => p.title.en);

type BadgePalette = { bg: string; color: string };
const badgePalette: Record<string, BadgePalette> = {
  'Blog':                 { bg: '#EFF6FF', color: '#1D4ED8' },
  '部落格':              { bg: '#EFF6FF', color: '#1D4ED8' },
  'Blog Series':          { bg: '#EEF2FF', color: '#4338CA' },
  '部落格系列':          { bg: '#EEF2FF', color: '#4338CA' },
  'SDK':                  { bg: '#F0FDF4', color: '#15803D' },
  'Certification':        { bg: '#FFFBEB', color: '#B45309' },
  '認證':                { bg: '#FFFBEB', color: '#B45309' },
  'GDG Kaohsiung Speaker':{ bg: '#FFF1F2', color: '#BE123C' },
  'GDG Kaohsiung 演講者':{ bg: '#FFF1F2', color: '#BE123C' },
  'DevOpsDays Speaker':   { bg: '#F5F3FF', color: '#6D28D9' },
  'DevOpsDays 演講者':    { bg: '#F5F3FF', color: '#6D28D9' },
};
const defaultPalette: BadgePalette = { bg: '#F4F4F5', color: '#52525B' };

function badgeStyle(type: string): string {
  const p = badgePalette[type] ?? defaultPalette;
  return `background:${p.bg};color:${p.color}`;
}
---

<CVSection title={lang === 'zh' ? '專案與亮點' : 'Projects &amp; Highlights'}>
  <ul class="cv-projects-list">
    {visibleItems.map((item) => {
      const localizedType = getLocalizedText(item.type as any, lang);
      return (
        <li class="cv-project-row">
          <span>
            {item.link ? (
              <a
                href={item.link}
                target="_blank"
                rel="noopener noreferrer"
                class="cv-project-link"
              >
                {getLocalizedText(item.title as any, lang)}
              </a>
            ) : (
              <span class="cv-project-text">{getLocalizedText(item.title as any, lang)}</span>
            )}
          </span>
          <span class="cv-badge" style={badgeStyle(localizedType)}>
            {localizedType}
          </span>
        </li>
      );
    })}
  </ul>
</CVSection>
