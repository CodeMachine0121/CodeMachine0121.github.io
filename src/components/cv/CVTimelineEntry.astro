---
interface Props {
  title: string;
  sub_title: string;
  years: string;
  details?: string;
}
const { title, sub_title, years, details } = Astro.props;
---

<div class="cv-entry">
  <div class="cv-entry__header">
    <h3 class="cv-entry__title">{title}</h3>
    <time class="cv-entry__date">{years}</time>
  </div>
  <p class="cv-entry__org">{sub_title}</p>
  {details && <p class="cv-entry__details">{details}</p>}
  <slot />
</div>
