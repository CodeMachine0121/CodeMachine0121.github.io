---
import CVSection from './CVSection.astro';
import { getLocalizedText } from '../../utils/i18n';
import type { HighlightItem, Language } from '../../types/cv';

interface Props {
  items: HighlightItem[];
  lang?: Language;
}
const { items, lang = 'en' } = Astro.props;
---

<CVSection title={lang === 'zh' ? '核心優勢' : 'Core Strengths'}>
  <div class="cv-highlights">
    {items.map((item) => (
      <div class="cv-highlight">
        <h3 class="cv-highlight__title">{getLocalizedText(item.title as any, lang)}</h3>
        <p class="cv-highlight__desc">{getLocalizedText(item.description as any, lang)}</p>
      </div>
    ))}
  </div>
</CVSection>
