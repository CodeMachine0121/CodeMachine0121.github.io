---
import type { Language } from '../../types/cv';

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const otherLang: Language = currentLang === 'en' ? 'zh' : 'en';
const otherLangLabel = otherLang === 'en' ? 'EN' : '中文';
---

<button
  class="cv-lang-switch no-print"
  aria-label={`Switch to ${otherLangLabel}`}
  title={`Switch to ${otherLangLabel}`}
  onclick={`window.location.href='/cv/${otherLang}'`}
>
  {otherLangLabel}
</button>

<style>
  .cv-lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    background: #ffffff;
    color: #52525b;
    border: 1px solid #e4e4e7;
    border-radius: 0.5rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    cursor: pointer;
    transition: all 150ms ease-in-out;
  }

  .cv-lang-switch:hover {
    background: #f4f4f5;
    color: #18181b;
    border-color: #d4d4d8;
  }

  .cv-lang-switch:active {
    transform: scale(0.95);
  }

  @media (max-width: 768px) {
    .cv-lang-switch {
      padding: 0.375rem 0.625rem;
      font-size: 0.8125rem;
    }
  }
</style>
