---
import CVSection from './CVSection.astro';
import CVTimelineEntry from './CVTimelineEntry.astro';
import type { ExperienceItem } from '../../types/cv';

interface Props {
  items: ExperienceItem[];
}
const { items } = Astro.props;
---

<CVSection title="Experience">
  <div class="space-y-5">
    {items.map((item) => (
      <CVTimelineEntry
        title={item.title}
        sub_title={item.sub_title}
        years={item.years}
        details={item.details?.en}
      >
        {item.achievements && item.achievements.length > 0 && (
          <ul class="space-y-0.5 pl-3">
            {item.achievements.map((a) => (
              <li class="text-sm text-gray-700 before:content-['•'] before:mr-2 before:text-gray-400">
                {a.en}
              </li>
            ))}
          </ul>
        )}
      </CVTimelineEntry>
    ))}
  </div>
</CVSection>
