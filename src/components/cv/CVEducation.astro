---
interface EducationItem {
  title: string;
  sub_title: string;
  years: string;
  details?: { en: string };
}

interface Props {
  items: EducationItem[];
}

const { items } = Astro.props;
---

<section class="mb-7">
  <h2 class="text-xs font-bold tracking-widest uppercase text-gray-500 mb-4 pb-1 border-b border-gray-200">
    Education
  </h2>

  <div class="space-y-4">
    {items.map((item) => (
      <div>
        <div class="flex items-baseline justify-between gap-4 mb-0.5">
          <h3 class="text-sm font-bold text-gray-900">{item.title}</h3>
          <time class="text-xs text-gray-500 whitespace-nowrap shrink-0">{item.years}</time>
        </div>
        <p class="text-sm font-semibold text-gray-600 mb-1">{item.sub_title}</p>
        {item.details && (
          <p class="text-sm text-gray-600 leading-relaxed">{item.details.en}</p>
        )}
      </div>
    ))}
  </div>
</section>
