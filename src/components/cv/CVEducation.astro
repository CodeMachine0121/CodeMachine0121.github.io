---
import CVSection from './CVSection.astro';
import CVTimelineEntry from './CVTimelineEntry.astro';
import type { EducationItem } from '../../types/cv';

interface Props {
  items: EducationItem[];
}
const { items } = Astro.props;
---

<CVSection title="Education">
  <div class="space-y-5">
    {items.map((item) => (
      <CVTimelineEntry
        title={item.title}
        sub_title={item.sub_title}
        years={item.years}
        details={item.details?.en}
      />
    ))}
  </div>
</CVSection>
