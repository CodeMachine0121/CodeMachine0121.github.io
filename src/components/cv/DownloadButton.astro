---
interface Props {
  fileName: string;
}

const { fileName } = Astro.props;
---

<button
  id="download-pdf-btn"
  data-filename={fileName}
  class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white font-semibold rounded-xl
         hover:opacity-90 active:scale-95 transition-all duration-150 shadow-md"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
  </svg>
  Download PDF
</button>

<script>
  const btn = document.getElementById('download-pdf-btn') as HTMLButtonElement;
  const fileName = btn?.dataset.filename ?? 'cv.pdf';

  function loadScript(src: string, check: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if ((window as any)[check]) { resolve(); return; }
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = () => reject();
      document.head.appendChild(s);
    });
  }

  btn?.addEventListener('click', async () => {
    btn.disabled = true;
    btn.textContent = 'Generating…';

    try {
      await Promise.all([
        loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js', 'html2canvas'),
        loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js', 'jspdf'),
      ]);

      const element = document.getElementById('cv-content');
      if (!element) throw new Error('cv-content not found');

      const canvasScale = 2;
      const canvas = await (window as any).html2canvas(element, {
        scale: canvasScale,
        useCORS: true,
        scrollY: -window.scrollY,
      });

      const { jsPDF } = (window as any).jspdf;
      const pdf = new jsPDF('p', 'mm', 'a4');
      const pageW = pdf.internal.pageSize.getWidth();
      const pageH = pdf.internal.pageSize.getHeight();
      const imgRatio = canvas.height / canvas.width;
      const imgH = pageW * imgRatio;
      const imgData = canvas.toDataURL('image/png');

      let imgX: number, imgY: number, imgW: number, imgFinalH: number;
      if (imgH <= pageH) {
        imgX = 0; imgY = (pageH - imgH) / 2; imgW = pageW; imgFinalH = imgH;
      } else {
        const s = pageH / imgH;
        imgW = pageW * s; imgFinalH = pageH;
        imgX = (pageW - imgW) / 2; imgY = 0;
      }
      pdf.addImage(imgData, 'PNG', imgX, imgY, imgW, imgFinalH);

      // Overlay clickable link regions
      const elemRect = element.getBoundingClientRect();
      const mmPerPx = imgW / (canvas.width / canvasScale);

      element.querySelectorAll('a[href]').forEach((a) => {
        const href = (a as HTMLAnchorElement).href;
        if (!href || href.startsWith('#') || href.startsWith('javascript')) return;
        const r = a.getBoundingClientRect();
        const x = imgX + (r.left - elemRect.left) * mmPerPx;
        const y = imgY + (r.top - elemRect.top) * mmPerPx;
        pdf.link(x, y, r.width * mmPerPx, r.height * mmPerPx, { url: href });
      });

      pdf.save(fileName);
    } catch {
      window.print();
    } finally {
      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>Download PDF`;
    }
  });
</script>
