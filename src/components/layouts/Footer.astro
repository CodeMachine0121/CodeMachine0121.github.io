---
import { Icon } from "astro-icon/components";
import { menuItems, socialLinks, basic } from "../../config/introduce.json";
const year = new Date().getFullYear();
---

<footer class="mt-8 border-t-[3px] border-dashed border-border">
    <div class="px-4 mx-auto sm:px-6 max-w-6xl py-12">
        <div class="flex flex-col items-center gap-8 xl:flex-row xl:justify-between">
            <!-- Sign-off note -->
            <div class="text-center xl:text-left">
                <p class="font-heading text-2xl text-ink -rotate-1">{basic?.name}</p>
                <p class="text-ink-soft mt-1">May the Bugs be with you.</p>
            </div>

            <div class="flex flex-col items-center gap-6 xl:flex-row xl:gap-10">
                <!-- Nav -->
                <ul class="flex flex-wrap items-center justify-center gap-x-7 gap-y-2">
                    {menuItems.map(menu => (
                        <li>
                            <a href={menu.link} title={menu.name.en} class="hd-link font-heading text-lg">
                                {menu.name.en}
                            </a>
                        </li>
                    ))}
                </ul>

                <!-- Socials in rough circles -->
                <ul class="flex items-center justify-center gap-4">
                    {socialLinks.map(social => (
                        <li>
                            <a href={social.link} title={social.iconName} target="_blank" rel="noopener noreferrer"
                               class="hd-icon-circle" aria-label={social.iconName}>
                                <Icon name={social.iconName} class="size-5" />
                            </a>
                        </li>
                    ))}
                </ul>
            </div>
        </div>

        <p class="text-center text-ink-soft text-sm mt-10">© {year} · scribbled with care</p>
    </div>
</footer>
