---
const { blog, isFirst } = Astro.props;
---

<a href={`/blogs/${blog.id}`} class="block group">
    <article class="hd-card hd-card--link flex flex-col md:flex-row items-start gap-5 p-5">
        <div class="flex-1">
            <h2 class="font-heading text-2xl text-ink leading-snug group-hover:text-accent transition-colors duration-100">
                {blog.data.title}
            </h2>
            <time datetime={blog.data.datetime} class="hd-badge mt-3">
                {new Date(blog.data.datetime).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="text-ink-soft mt-4 line-clamp-2 leading-relaxed">{blog.data.description}</p>
        </div>
        {blog.data.image && (
            <div class="w-full md:w-44 shrink-0 overflow-hidden border-2 border-border" style="border-radius: 15px 225px 15px 255px / 255px 15px 225px 15px;">
                <img src={blog.data.image} alt={blog.data.title}
                    loading={isFirst ? "eager" : "lazy"}
                    class="w-full h-32 md:h-28 object-cover object-center group-hover:scale-105 transition-transform duration-300" />
            </div>
        )}
    </article>
</a>
