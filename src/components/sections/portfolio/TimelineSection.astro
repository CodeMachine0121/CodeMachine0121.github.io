---
import TimelineItem from './TimelineItem.astro';

interface Item {
  title: string;
  sub_title: string;
  years: string;
  details?: { en: string };
  achievements?: { en: string }[];
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

<section class="relative py-14 sm:py-20">
  <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
    <!-- Section header -->
    <div class="mb-12 sm:mb-16">
      <span class="hd-label" data-reveal="fade-up">{title}</span>
      <span class="hd-squiggle mt-5" data-reveal="fade-in" data-reveal-delay="100" aria-hidden="true"></span>
    </div>

    <!-- Timeline: a dashed pencil line down the left margin -->
    <div class="relative pl-6 sm:pl-10 border-l-[3px] border-dashed border-border">
      {items.map((item, index) => (
        <div data-reveal={index % 2 === 0 ? "slide-left" : "slide-right"} data-reveal-delay={100 * index}>
          <TimelineItem
            title={item.title}
            sub_title={item.sub_title}
            years={item.years}
            details={item?.details}
            achievements={item.achievements}
          />
        </div>
      ))}
    </div>
  </div>
</section>
