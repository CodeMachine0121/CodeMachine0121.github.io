---
interface Props {
  title: string;
  sub_title: string;
  years: string;
  details?: { en: string };
  achievements?: { en: string }[];
  isLast?: boolean;
}

const { title, sub_title, years, details, achievements } = Astro.props;
---

<div class="relative group mb-10 last:mb-0">
  <!-- Node dot sitting on the dashed timeline -->
  <span class="absolute -left-[2.1rem] sm:-left-[3.1rem] top-7 w-4 h-4 bg-accent border-2 border-border rounded-full ring-4 ring-paper"></span>

  <div class="hd-card hd-card--link p-5 sm:p-6">
    <!-- Year sticky-tag -->
    <span class="hd-badge mb-3 font-heading">{years}</span>

    <h3 class="font-heading text-2xl sm:text-3xl text-ink leading-tight mb-1">
      {title}
    </h3>

    <div class="flex items-center gap-2 mb-4 text-accent-2 font-heading text-lg">
      <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg>
      {sub_title}
    </div>

    {details && (
      <p class="text-ink leading-relaxed mb-5">{details.en}</p>
    )}

    {achievements && achievements.length > 0 && (
      <div>
        <span class="hd-label !text-xs mb-4">Key Achievements</span>
        <ul class="mt-4 space-y-2.5">
          {achievements.map((achievement) => (
            <li class="flex items-start gap-3 text-ink">
              <!-- hand-drawn check -->
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 13l5 5L20 6" />
              </svg>
              <span class="flex-1">{achievement.en}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</div>
