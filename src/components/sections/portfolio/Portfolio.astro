---
import Project from '../Project.astro';
import PortfolioFilter from '../../common/PortfolioFilter.astro';
import { projects } from '../../../config/introduce.json';
---

<section class="relative py-16 sm:py-20">
    <div class="container px-4 sm:px-6 mx-auto max-w-6xl">
        <!-- Section header -->
        <div class="text-center mb-12 sm:mb-16">
            <span class="hd-label" data-reveal="fade-up">My Portfolio</span>
            <h2 class="font-heading text-4xl sm:text-5xl text-ink mt-6 mb-4" data-reveal="fade-up" data-reveal-delay="50">
                Stuff I've built &amp; shared
            </h2>
            <p class="text-lg sm:text-xl text-ink-soft max-w-2xl mx-auto leading-relaxed" data-reveal="fade-up" data-reveal-delay="100">
                A pile of projects, talks and writing — pinned up like notes on a board.
            </p>
            <span class="hd-squiggle mx-auto mt-6" data-reveal="fade-in" data-reveal-delay="150" aria-hidden="true"></span>
        </div>

        <!-- Filter -->
        <PortfolioFilter />

        <!-- Projects grid -->
        <div id="portfolio-grid" class="grid grid-cols-1 gap-8 sm:gap-10 md:grid-cols-2 xl:grid-cols-3">
            {projects.map((project, index) => (
                <div
                    class="filtered-in"
                    data-reveal="fade-up"
                    data-reveal-delay={50 * (index % 6)}
                    data-project-type={project.type.en}
                >
                    <Project
                        imageUrl={project.imageUrl}
                        title={project.title}
                        type={project.type}
                        link={project.link}
                        index={index}
                    />
                </div>
            ))}
        </div>
    </div>
</section>
