---
const { imageUrl, title, type, link, index = 0 } = Astro.props;
const finalImageUrl = imageUrl === ""
    ? "https://images.unsplash.com/photo-1709547228697-fa1f424a3f39?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    : imageUrl;

// Alternate resting tilt so the grid feels pinned-up, not gridded.
const tilt = (index % 2 === 0 ? -1 : 1) * (1 + (index % 2));
---

<a href={link} target="_blank" rel="noopener noreferrer" class="block group h-full">
    <article
        class="hd-card hd-card--link flex flex-col h-full !p-0 overflow-hidden"
        style={`transform: rotate(${tilt}deg);`}
    >
        <!-- Image -->
        <div class="relative h-48 overflow-hidden shrink-0 border-b-2 border-border">
            <div
                class="absolute inset-0 bg-cover bg-center transition-transform duration-300 ease-out group-hover:scale-105"
                style={`background-image: url('${finalImageUrl}');`}
            ></div>
            <!-- Type sticky-note tag -->
            <span class="hd-badge absolute top-3 left-3 z-10">{type.en}</span>
        </div>

        <!-- Body -->
        <div class="flex flex-col flex-grow p-5">
            <h3 class="font-heading text-xl text-ink leading-snug line-clamp-2 mb-auto group-hover:text-accent transition-colors duration-100">
                {title.en}
            </h3>

            <div class="mt-5 pt-4 border-t-2 border-dashed border-border flex items-center justify-between">
                <span class="font-heading text-ink-soft group-hover:text-accent transition-colors duration-100">View project</span>
                <span class="hd-icon-circle !w-9 !h-9">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </span>
            </div>
        </div>
    </article>
</a>
