---
import CVHeader from '../components/cv/CVHeader.astro';
import CVSummary from '../components/cv/CVSummary.astro';
import CVExperience from '../components/cv/CVExperience.astro';
import CVEducation from '../components/cv/CVEducation.astro';
import CVProjects from '../components/cv/CVProjects.astro';
import DownloadButton from '../components/cv/DownloadButton.astro';
import { basic, experiences, education, projects, socialLinks } from '../config/cv.json';
import '../styles/theme.css';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${basic.name} – Curriculum Vitae`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{basic.name} – CV</title>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: #f5f5f5;
        color: #111;
        -webkit-font-smoothing: antialiased;
      }

      /* Action bar hidden in print */
      @media print {
        .no-print { display: none !important; }
        body { background: white; }
        .cv-paper {
          box-shadow: none !important;
          margin: 0 !important;
          padding: 20mm 18mm !important;
          max-width: 100% !important;
        }
      }
    </style>
  </head>

  <body>
    <!-- Action bar -->
    <div class="no-print" style="position:sticky;top:0;z-index:10;background:#fff;border-bottom:1px solid #e5e7eb;box-shadow:0 1px 3px rgba(0,0,0,.08);">
      <div style="max-width:780px;margin:0 auto;padding:10px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;">
        <a
          href="/"
          style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:500;color:#6b7280;text-decoration:none;"
          onmouseover="this.style.color='#111'" onmouseout="this.style.color='#6b7280'"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Home
        </a>
        <DownloadButton fileName={basic.cv_file_name} />
      </div>
    </div>

    <!-- CV Paper -->
    <div style="padding:32px 16px 64px;">
      <div
        id="cv-content"
        class="cv-paper"
        style="max-width:780px;margin:0 auto;background:#fff;padding:48px 52px;box-shadow:0 4px 24px rgba(0,0,0,.10);border-radius:4px;"
      >
        <CVHeader basic={basic} socialLinks={socialLinks} />

        <div style="margin-top:24px;">
          <CVSummary summary={basic.summary.en} />
          <CVExperience items={experiences} />
          <CVEducation items={education} />
          <CVProjects items={projects} />
        </div>
      </div>
    </div>
  </body>
</html>
