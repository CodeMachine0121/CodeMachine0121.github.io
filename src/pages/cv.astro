---
import CVHeader from '../components/cv/CVHeader.astro';
import CVSummary from '../components/cv/CVSummary.astro';
import CVHighlights from '../components/cv/CVHighlights.astro';
import CVExperience from '../components/cv/CVExperience.astro';
import CVEducation from '../components/cv/CVEducation.astro';
import CVProjects from '../components/cv/CVProjects.astro';
import DownloadButton from '../components/cv/DownloadButton.astro';
import profilePicture from '../assets/profile-picture.png';
import cvData from '../config/cv.json';
import '../styles/cv.scss';

const { basic, highlights, experiences, education, projects, socialLinks } = cvData;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${basic.name} – Curriculum Vitae`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{basic.name} – CV</title>
  </head>

  <body>
    <!-- Back to Home -->
    <a href="/" class="no-print cv-back-link" aria-label="Back to home">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
      Home
    </a>

    <!-- Download PDF -->
    <DownloadButton fileName={basic.cv_file_name} />

    <!-- CV Paper -->
    <div class="flex justify-center px-4 pt-14 pb-16">
      <div id="cv-content" class="cv-paper">
        <CVHeader basic={basic} socialLinks={socialLinks} profilePicture={profilePicture} />

        <CVSummary summary={basic.summary.en} />
        {highlights && highlights.length > 0 && <CVHighlights items={highlights} />}
        <CVExperience items={experiences} />
        <CVEducation items={education} />
        <CVProjects items={projects} />
      </div>
    </div>

    <!-- Intersection Observer for entrance animations -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              el.style.animationDelay = `${i * 40}ms`;
              el.classList.add('is-visible');
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.05 }
      );

      document.querySelectorAll('.cv-animate').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
