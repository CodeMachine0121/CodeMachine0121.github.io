---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import PostNavigation from '../../components/sections/blog/PostNavigation.astro';
import ReadingProgress from '../../components/common/ReadingProgress.astro';
import GiscusComments from '../../components/common/GiscusComments.astro';
import BackToTop from '../../components/common/BackToTop.astro';
import StickyNotes from '../../components/common/StickyNotes.astro';
import { getAdjacentPosts, getAdjacentSeriesPosts, getPublishedBlogs } from '../../utils/series';

export const getStaticPaths = async () => {
    const blogs = await getPublishedBlogs();
    return blogs.map(blog => ({
        params: { slug: blog.id },
        props: { blog }
    }));
}

type Props = {
    blog: CollectionEntry<"blogs">
}

const {blog} = Astro.props;
const {Content} = await render(blog);

let prevPost, nextPost;

if (blog.data.parent) {
    const adjacent = await getAdjacentSeriesPosts(blog.id, blog.data.parent);
    prevPost = adjacent.prevPost;
    nextPost = adjacent.nextPost;
} else {
    const adjacent = await getAdjacentPosts(blog.id);
    prevPost = adjacent.prevPost;
    nextPost = adjacent.nextPost;
}
---

<Layout title={blog.data.title}>
    <ReadingProgress />
    <article class="w-full max-w-none md:max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
        <header class="mb-12 pb-8 border-b-[3px] border-dashed border-border">
            {blog.data.parent && (
                <span class="hd-badge mb-4">{blog.data.parent}</span>
            )}
            <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl mb-4 leading-tight text-ink">{blog.data.title}</h1>
            {blog.data.description && (
                <p class="text-lg md:text-xl text-ink-soft mb-5 leading-relaxed">{blog.data.description}</p>
            )}
            <time datetime={blog.data.datetime} class="hd-badge">
                {new Date(blog.data.datetime).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
        </header>

        {blog.data.image && (
            <div class="overflow-hidden border-[3px] border-border mb-10 rotate-1" style="border-radius: 15px 225px 15px 255px / 255px 15px 225px 15px; box-shadow: 6px 6px 0 0 var(--hd-shadow);">
                <img
                    src={blog.data.image}
                    alt={blog.data.title}
                    loading="eager"
                    class="w-full max-h-96 object-cover"
                />
            </div>
        )}

        <div class="blog-content prose prose-lg dark:prose-invert">
            <Content />
        </div>

        <GiscusComments />

        <PostNavigation {prevPost} {nextPost} />
        <BackToTop />
    </article>

    <StickyNotes />

    <script>
        import { toggleMarkdownTheme } from "../../scripts/theme";
        import "../../scripts/mobileFixes";

        const theme = document.documentElement.dataset.theme;
        toggleMarkdownTheme(theme);
    </script>
</Layout>
