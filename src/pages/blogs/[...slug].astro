---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

import Layout from '../../layouts/Layout.astro';
import PostNavigation from '../../components/sections/blog/PostNavigation.astro';
import ReadingProgress from '../../components/common/ReadingProgress.astro';
import GiscusComments from '../../components/common/GiscusComments.astro';
import BackToTop from '../../components/common/BackToTop.astro';
import { getAdjacentPosts, getAdjacentSeriesPosts } from '../../utils/series';

export const getStaticPaths = async () => {
    const blogs = await getCollection("blogs");
    return blogs.map(blog => ({
        params: { slug: blog.id },
        props: { blog }
    }));
}

type Props = {
    blog: CollectionEntry<"blogs">
}

const {blog} = Astro.props;
const {Content} = await render(blog);

let prevPost, nextPost;

if (blog.data.parent) {
    const adjacent = await getAdjacentSeriesPosts(blog.id, blog.data.parent);
    prevPost = adjacent.prevPost;
    nextPost = adjacent.nextPost;
} else {
    const adjacent = await getAdjacentPosts(blog.id);
    prevPost = adjacent.prevPost;
    nextPost = adjacent.nextPost;
}
---

<Layout title={blog.data.title}>
    <ReadingProgress />
    <article class="w-full max-w-none md:max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
        <header class="mb-12 text-center md:text-left pb-8 border-b border-[var(--color-border)]">
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight text-text">{blog.data.title}</h1>
            {blog.data.description && (
                <p class="text-base md:text-lg text-offset mb-4 leading-relaxed">{blog.data.description}</p>
            )}
            <time datetime={blog.data.datetime} class="text-sm text-offset block">
                {new Date(blog.data.datetime).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
        </header>

        <div class="blog-content prose prose-lg dark:prose-invert">
            <Content />
        </div>

        <GiscusComments />

        <PostNavigation {prevPost} {nextPost} />
        <BackToTop />
    </article>

    <script>
        import { toggleMarkdownTheme } from "../../scripts/theme";
        import "../../scripts/mobileFixes";

        const theme = document.documentElement.dataset.theme;
        toggleMarkdownTheme(theme);
    </script>
</Layout>
