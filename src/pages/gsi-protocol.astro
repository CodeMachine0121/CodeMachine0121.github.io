---
// GSI-Protocol Landing Page
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GSI-Protocol — Specification-Driven Development for AI</title>
    <meta name="description" content="Transform user requirements into production-ready code through a structured 4-phase AI workflow: Gherkin → Structure → Implement. Works with Claude Code, Codex, and GitHub Copilot.">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <!-- Tailwind CSS -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '#3B82F6',
                        'brand-dark': '#2563EB',
                        surface: '#0F172A',
                        'surface-2': '#1E293B',
                        'surface-3': '#334155',
                        muted: '#94A3B8',
                        subtle: '#475569',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'Fira Code', 'monospace'],
                    },
                    animation: {
                        'fade-up': 'fadeUp 0.6s ease-out forwards',
                        'glow-pulse': 'glowPulse 3s ease-in-out infinite',
                    },
                }
            }
        }
    </script>

    <style>
        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: #020817;
            color: #F1F5F9;
            -webkit-font-smoothing: antialiased;
        }

        /* Dot grid background */
        .dot-grid {
            background-image: radial-gradient(circle, #334155 1px, transparent 1px);
            background-size: 28px 28px;
        }

        /* Gradient text */
        .gradient-text {
            background: linear-gradient(135deg, #60A5FA 0%, #818CF8 50%, #A78BFA 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Glow effect */
        .glow-blue {
            box-shadow: 0 0 40px rgba(59, 130, 246, 0.15), 0 0 80px rgba(59, 130, 246, 0.05);
        }

        .glow-border {
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        /* Terminal */
        .terminal {
            background: #0D1117;
            border: 1px solid #30363D;
            border-radius: 12px;
            overflow: hidden;
        }

        .terminal-bar {
            background: #161B22;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 6px;
            border-bottom: 1px solid #30363D;
        }

        .terminal-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .terminal-body {
            padding: 20px 24px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            line-height: 1.8;
        }

        .token-comment { color: #6A737D; }
        .token-cmd { color: #58A6FF; }
        .token-arg { color: #D2A8FF; }
        .token-string { color: #7EE787; }
        .token-prompt { color: #3B82F6; }
        .token-output { color: #8B949E; }

        /* Phase cards */
        .phase-card {
            background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
            border: 1px solid #1E293B;
            transition: border-color 0.2s ease, transform 0.2s ease;
        }

        .phase-card:hover {
            border-color: rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
        }

        /* Feature card */
        .feature-card {
            background: #0F172A;
            border: 1px solid #1E293B;
            transition: border-color 0.2s ease, background 0.2s ease;
        }

        .feature-card:hover {
            border-color: rgba(59, 130, 246, 0.3);
            background: #111827;
        }

        /* Nav glass */
        .nav-glass {
            background: rgba(2, 8, 23, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(51, 65, 85, 0.6);
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #020817; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes glowPulse {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 0.8; }
        }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>

    <!-- ─── Background ─── -->
    <div class="fixed inset-0 dot-grid opacity-30 pointer-events-none" aria-hidden="true"></div>
    <div class="fixed inset-0 pointer-events-none" aria-hidden="true"
         style="background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.12) 0%, transparent 60%);">
    </div>

    <!-- ─── Navigation ─── -->
    <nav class="fixed top-4 left-4 right-4 z-50 nav-glass rounded-2xl shadow-2xl">
        <div class="max-w-7xl mx-auto px-5">
            <div class="flex justify-between items-center h-14">
                <!-- Logo -->
                <a href="#" class="flex items-center gap-2.5 cursor-pointer">
                    <div class="w-7 h-7 rounded-lg bg-brand flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none">
                            <path d="M9 12L11 14L15 10M7 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2h-2M7 3a2 2 0 012-2h6a2 2 0 012 2M7 3h10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <span class="font-mono font-semibold text-white text-sm tracking-wide">GSI-Protocol</span>
                </a>

                <!-- Desktop nav -->
                <div class="hidden md:flex items-center gap-8">
                    <a href="#features" class="text-sm text-slate-400 hover:text-white transition-colors duration-150 cursor-pointer">Features</a>
                    <a href="#workflow" class="text-sm text-slate-400 hover:text-white transition-colors duration-150 cursor-pointer">Workflow</a>
                    <a href="#quickstart" class="text-sm text-slate-400 hover:text-white transition-colors duration-150 cursor-pointer">Quick Start</a>
                    <a href="#commands" class="text-sm text-slate-400 hover:text-white transition-colors duration-150 cursor-pointer">Commands</a>
                </div>

                <!-- CTA -->
                <div class="flex items-center gap-3">
                    <a href="https://github.com/CodeMachine0121/GSI-Protocol" target="_blank" rel="noopener noreferrer"
                       class="hidden sm:flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-300 hover:text-white border border-slate-700 hover:border-slate-500 rounded-lg transition-all duration-150 cursor-pointer">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                        </svg>
                        GitHub
                    </a>
                    <a href="#quickstart"
                       class="px-4 py-2 text-sm font-semibold bg-brand hover:bg-brand-dark text-white rounded-lg transition-colors duration-150 cursor-pointer">
                        Get Started
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- ─── Hero ─── -->
    <section class="relative pt-36 pb-24 px-4 overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-16 items-center">

                <!-- Left: Copy -->
                <div class="space-y-8">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-mono font-medium text-blue-400 bg-blue-400/10 border border-blue-400/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                        Specification-Driven Development · v1.0.14
                    </div>

                    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight">
                        <span class="text-white">From Idea</span><br>
                        <span class="gradient-text">to Production</span><br>
                        <span class="text-white">Automatically</span>
                    </h1>

                    <p class="text-lg text-slate-400 leading-relaxed max-w-lg">
                        GSI-Protocol is an AI-powered SDD workflow that transforms any requirement into production-ready code through four structured phases — powered by Gherkin, Structure, and Implement.
                    </p>

                    <div class="flex flex-wrap gap-4">
                        <a href="#quickstart"
                           class="inline-flex items-center gap-2 px-6 py-3.5 bg-brand hover:bg-brand-dark text-white font-semibold rounded-xl transition-all duration-150 cursor-pointer shadow-lg shadow-blue-500/20 hover:shadow-blue-500/30">
                            Install Now
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                            </svg>
                        </a>
                        <a href="https://github.com/CodeMachine0121/GSI-Protocol" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-2 px-6 py-3.5 bg-surface-2 hover:bg-surface-3 text-slate-200 font-semibold rounded-xl border border-surface-3 hover:border-slate-500 transition-all duration-150 cursor-pointer">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                            </svg>
                            View on GitHub
                        </a>
                    </div>

                    <!-- Stats -->
                    <div class="flex gap-8 pt-2">
                        <div>
                            <div class="text-2xl font-bold text-white">4</div>
                            <div class="text-sm text-slate-500 mt-0.5">Phases</div>
                        </div>
                        <div class="w-px bg-surface-3"></div>
                        <div>
                            <div class="text-2xl font-bold text-white">3</div>
                            <div class="text-sm text-slate-500 mt-0.5">AI Platforms</div>
                        </div>
                        <div class="w-px bg-surface-3"></div>
                        <div>
                            <div class="text-2xl font-bold text-white">1</div>
                            <div class="text-sm text-slate-500 mt-0.5">Command</div>
                        </div>
                    </div>
                </div>

                <!-- Right: Terminal Demo -->
                <div class="relative">
                    <!-- Glow -->
                    <div class="absolute -inset-4 bg-blue-500/5 rounded-2xl blur-2xl pointer-events-none"></div>

                    <div class="terminal glow-blue relative">
                        <!-- Title bar -->
                        <div class="terminal-bar">
                            <div class="terminal-dot" style="background: #FF5F57;"></div>
                            <div class="terminal-dot" style="background: #FFBD2E;"></div>
                            <div class="terminal-dot" style="background: #28CA41;"></div>
                            <span class="ml-3 text-xs text-slate-500 font-mono">claude-code ~ project</span>
                        </div>

                        <!-- Content -->
                        <div class="terminal-body">
                            <div><span class="token-comment"># Run complete SDD workflow in one command</span></div>
                            <div class="mt-3"><span class="token-prompt">$</span> <span class="token-cmd">/sdd-auto</span> <span class="token-arg">Add user authentication with JWT</span></div>
                            <div class="mt-2 token-output">→ Phase 1/4: Generating Gherkin specification...</div>
                            <div class="token-output">  ✓ features/user-auth.feature created</div>
                            <div class="mt-1 token-output">→ Phase 2/4: Designing architecture...</div>
                            <div class="token-output">  ✓ docs/features/user-auth/architecture.md created</div>
                            <div class="mt-1 token-output">→ Phase 3/4: Implementing code...</div>
                            <div class="token-output">  ✓ src/auth/jwt.service.ts created</div>
                            <div class="token-output">  ✓ src/auth/auth.middleware.ts created</div>
                            <div class="mt-1 token-output">→ Phase 4/4: Verifying implementation...</div>
                            <div class="token-output">  ✓ All scenarios passed</div>
                            <div class="mt-2"><span class="token-string">✓ Feature complete. 4 files generated.</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ─── GSI Pillars ─── -->
    <section class="py-16 px-4">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="flex items-center gap-4 p-5 rounded-xl bg-surface-2 border border-surface-3">
                    <div class="w-10 h-10 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="font-mono font-bold text-blue-400 text-sm">G</span>
                    </div>
                    <div>
                        <div class="font-semibold text-white text-sm">Gherkin</div>
                        <div class="text-xs text-slate-500 mt-0.5">BDD specification in plain language</div>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-5 rounded-xl bg-surface-2 border border-surface-3">
                    <div class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="font-mono font-bold text-purple-400 text-sm">S</span>
                    </div>
                    <div>
                        <div class="font-semibold text-white text-sm">Structure</div>
                        <div class="text-xs text-slate-500 mt-0.5">Language-agnostic architecture</div>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-5 rounded-xl bg-surface-2 border border-surface-3">
                    <div class="w-10 h-10 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
                        <span class="font-mono font-bold text-emerald-400 text-sm">I</span>
                    </div>
                    <div>
                        <div class="font-semibold text-white text-sm">Implement</div>
                        <div class="text-xs text-slate-500 mt-0.5">Production-ready code generation</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ─── Features ─── -->
    <section id="features" class="py-24 px-4">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-16">
                <p class="text-sm font-mono text-brand mb-3">// Features</p>
                <h2 class="text-4xl sm:text-5xl font-bold text-white mb-5">
                    Built for how<br>developers actually work
                </h2>
                <p class="text-slate-400 max-w-xl mx-auto">
                    Every aspect of GSI-Protocol is designed to eliminate the friction between idea and production code.
                </p>
            </div>

            <!-- Bento Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

                <!-- Feature 1: Multi-Platform (wide) -->
                <div class="feature-card rounded-2xl p-6 cursor-default lg:col-span-2">
                    <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-5">
                        <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Multi-Platform Support</h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-5">
                        Works seamlessly with your existing AI assistant. No lock-in, no migration required.
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1.5 rounded-lg bg-surface-3/60 text-slate-300 text-xs font-mono border border-slate-700">Claude Code</span>
                        <span class="px-3 py-1.5 rounded-lg bg-surface-3/60 text-slate-300 text-xs font-mono border border-slate-700">Codex (OpenAI)</span>
                        <span class="px-3 py-1.5 rounded-lg bg-surface-3/60 text-slate-300 text-xs font-mono border border-slate-700">GitHub Copilot</span>
                    </div>
                </div>

                <!-- Feature 2: Language Agnostic -->
                <div class="feature-card rounded-2xl p-6 cursor-default">
                    <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center mb-5">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Language Agnostic</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Architecture design is independent of programming language — TypeScript, Python, Go, Rust — it works everywhere.
                    </p>
                </div>

                <!-- Feature 3: Automated Workflow -->
                <div class="feature-card rounded-2xl p-6 cursor-default">
                    <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Automated Workflow</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Execute the complete 4-phase development cycle with a single <code class="text-emerald-400 font-mono">/sdd-auto</code> command.
                    </p>
                </div>

                <!-- Feature 4: BDD Integration -->
                <div class="feature-card rounded-2xl p-6 cursor-default">
                    <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-5">
                        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">BDD Integration</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Built-in Gherkin support turns business requirements into living documentation and executable specs.
                    </p>
                </div>

                <!-- Feature 5: Project-Aware (wide) -->
                <div class="feature-card rounded-2xl p-6 cursor-default lg:col-span-2">
                    <div class="flex items-start gap-5">
                        <div class="w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-white mb-2">Project-Aware Context</h3>
                            <p class="text-slate-400 text-sm leading-relaxed">
                                GSI-Protocol automatically detects your project's tech stack, conventions, and existing patterns. Architecture decisions adapt to what you already have — no manual configuration needed.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Feature 6: Role-Based -->
                <div class="feature-card rounded-2xl p-6 cursor-default">
                    <div class="w-10 h-10 rounded-xl bg-rose-500/10 border border-rose-500/20 flex items-center justify-center mb-5">
                        <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white mb-2">Role-Based Phases</h3>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        Mirrors real team workflow: PM → Architect → Engineer → QA, each phase with a clear responsibility.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <!-- ─── Workflow ─── -->
    <section id="workflow" class="py-24 px-4">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-16">
                <p class="text-sm font-mono text-brand mb-3">// 4-Phase Workflow</p>
                <h2 class="text-4xl sm:text-5xl font-bold text-white mb-5">
                    Structured from<br>requirement to release
                </h2>
                <p class="text-slate-400 max-w-xl mx-auto">
                    Each phase has a clearly defined role, input, and output. No ambiguity, no guesswork.
                </p>
            </div>

            <!-- Phase Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

                <!-- Phase 1 -->
                <div class="phase-card rounded-2xl p-6 cursor-default relative overflow-hidden">
                    <div class="absolute top-4 right-4 text-7xl font-black text-surface-3/50 leading-none select-none">1</div>
                    <div class="relative">
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-mono mb-4">
                            PM Role
                        </div>
                        <h3 class="text-xl font-bold text-white mb-3">Specification</h3>
                        <p class="text-slate-400 text-sm leading-relaxed mb-5">
                            Converts your requirement into a structured Gherkin feature file with Given/When/Then scenarios.
                        </p>
                        <div class="p-3 rounded-lg bg-black/30 border border-surface-3">
                            <div class="font-mono text-xs text-slate-400">
                                <span class="text-blue-400">/sdd-spec</span> &lt;requirement&gt;<br>
                                <span class="text-slate-600">→ features/*.feature</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Phase 2 -->
                <div class="phase-card rounded-2xl p-6 cursor-default relative overflow-hidden">
                    <div class="absolute top-4 right-4 text-7xl font-black text-surface-3/50 leading-none select-none">2</div>
                    <div class="relative">
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400 text-xs font-mono mb-4">
                            Architect Role
                        </div>
                        <h3 class="text-xl font-bold text-white mb-3">Architecture</h3>
                        <p class="text-slate-400 text-sm leading-relaxed mb-5">
                            Designs a language-agnostic architecture document from your Gherkin spec, defining modules and interfaces.
                        </p>
                        <div class="p-3 rounded-lg bg-black/30 border border-surface-3">
                            <div class="font-mono text-xs text-slate-400">
                                <span class="text-purple-400">/sdd-arch</span> &lt;feature&gt;<br>
                                <span class="text-slate-600">→ docs/*/architecture.md</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Phase 3 -->
                <div class="phase-card rounded-2xl p-6 cursor-default relative overflow-hidden">
                    <div class="absolute top-4 right-4 text-7xl font-black text-surface-3/50 leading-none select-none">3</div>
                    <div class="relative">
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-mono mb-4">
                            Engineer Role
                        </div>
                        <h3 class="text-xl font-bold text-white mb-3">Implementation</h3>
                        <p class="text-slate-400 text-sm leading-relaxed mb-5">
                            Generates production-ready source code based on the architecture document, respecting your project's conventions.
                        </p>
                        <div class="p-3 rounded-lg bg-black/30 border border-surface-3">
                            <div class="font-mono text-xs text-slate-400">
                                <span class="text-emerald-400">/sdd-impl</span> &lt;feature&gt;<br>
                                <span class="text-slate-600">→ Source code files</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Phase 4 -->
                <div class="phase-card rounded-2xl p-6 cursor-default relative overflow-hidden">
                    <div class="absolute top-4 right-4 text-7xl font-black text-surface-3/50 leading-none select-none">4</div>
                    <div class="relative">
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs font-mono mb-4">
                            QA Role
                        </div>
                        <h3 class="text-xl font-bold text-white mb-3">Verification</h3>
                        <p class="text-slate-400 text-sm leading-relaxed mb-5">
                            Verifies the implementation against every Gherkin scenario and generates a conclusion report.
                        </p>
                        <div class="p-3 rounded-lg bg-black/30 border border-surface-3">
                            <div class="font-mono text-xs text-slate-400">
                                <span class="text-amber-400">/sdd-verify</span> &lt;feature&gt;<br>
                                <span class="text-slate-600">→ docs/*/conclusion.md</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Or use one command -->
            <div class="mt-8 text-center">
                <div class="inline-flex items-center gap-3 px-6 py-3.5 rounded-xl bg-surface-2 border border-surface-3">
                    <span class="text-slate-400 text-sm">Or run all 4 phases at once:</span>
                    <code class="font-mono text-sm text-brand">/sdd-auto &lt;your requirement&gt;</code>
                </div>
            </div>
        </div>
    </section>

