<section class="relative grid-bg min-h-screen flex flex-col items-center justify-center px-6 py-20 text-center overflow-hidden">

    <!-- Radial glow -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] rounded-full pointer-events-none"
